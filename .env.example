# Glance configuration — copy to a real `.env` and fill in what you use.
#
# For the VOICE COMPANION (`glance run`), put this at:  glance/shell/.env
# For a frozen install (installer .exe / .deb / .AppImage), put it at:
#   Windows: %LOCALAPPDATA%\Glance\.env
#   Linux:   ~/.local/share/Glance/.env
# For the FILE ORGANIZER  (`glance organize`), the project root `.env` is fine.
# (A first-run setup wizard can also fill these in for you.)

# ─────────────────────────────────────────────────────────────────────
# VOICE COMPANION (glance run) — one LLM key is enough. Pick any.
# You can switch providers from the tray menu at runtime.
# ─────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...          # provider: claude
# OPENAI_API_KEY=sk-...                 # provider: openai
# GOOGLE_API_KEY=AIza...                # provider: gemini
# (No key? Ollama runs locally for free — install from https://ollama.com)

DEEPGRAM_API_KEY=...                    # recommended: fast, accurate speech-to-text
                                        # (without it, falls back to local Whisper)

GLANCE_ACTIVE_LLM=claude                # claude | openai | gemini | ollama | copilot
GLANCE_ACTIVE_MODEL=                    # optional: pin a specific model id
GLANCE_HOTKEY=ctrl+alt+m                # push-to-talk hotkey (hold to talk)

# ─────────────────────────────────────────────────────────────────────
# FILE ORGANIZER (glance organize)  — pick ONE provider, or use free modes
# ─────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...        # provider: claude  (best quality)
# OPENAI_API_KEY=sk-...               # provider: openai
# GOOGLE_API_KEY=AIza...              # provider: gemini

# --- Local / free (no key needed) ---
# OLLAMA_HOST=http://localhost:11434  # provider: ollama (default if no cloud key)
# GLANCE_OLLAMA_MODEL=llama3.1

# --- Force a provider regardless of keys ---
# GLANCE_PROVIDER=heuristic           # heuristic | ollama | claude | openai | gemini

# ─────────────────────────────────────────────────────────────────────
# OPTIONAL — Gmail / Calendar via the Google API (see glance/shell/google_workspace.py)
# ─────────────────────────────────────────────────────────────────────
# Not set here — drop a Desktop OAuth client at ~/.glance/google_credentials.json.
# Without it, Glance just opens your logged-in Gmail/Calendar in the browser instead.
